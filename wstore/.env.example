# --- PostgreSQL ---
# Lokal: postgresql://user:password@localhost:5432/wstore
# Railway/Neon: ulardan berilgan connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wstore?schema=public"

# --- Auth.js (NextAuth v5) ---
# Terminalda hosil qiling:  npx auth secret
AUTH_SECRET="o'zgartiring-tasodifiy-uzun-satr"

# --- Google OAuth ---
# https://console.cloud.google.com/ -> Credentials -> OAuth client ID (Web)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="xxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxx"

# --- Ilova ---
APP_URL="http://localhost:3000"
UZS_RATE="12600"   # 1 USD -> so'm (to'lov konvertatsiyasi uchun)

# --- Cloudflare R2 (kod .zip fayllari) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="wstore-files"

# --- To'lov: Payme ---
PAYME_MERCHANT_ID=""
PAYME_KEY=""              # webhook Authorization tekshiruvi uchun

# --- To'lov: Click ---
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""       # webhook signature tekshiruvi uchun
