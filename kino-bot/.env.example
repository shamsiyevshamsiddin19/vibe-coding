# ==== TELEGRAM ====
BOT_TOKEN=123456789:AA-your-bot-token-here
BOT_USERNAME=YourBotUsername

# Admin ID lar (vergul bilan ajrating)
ADMIN_IDS=111111111,222222222

# ==== POSTGRESQL ====
# Variant 1: to'liq DSN
DATABASE_URL=postgresql://kino:CHANGE_ME@localhost:5432/kino
# Variant 2: alohida (DATABASE_URL bo'sh bo'lsa ishlatiladi)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kino
DB_USER=kino
DB_PASS=CHANGE_ME

# ==== TMDB ====
TMDB_KEY=your-tmdb-api-read-access-token

# ==== KANALLAR / GURUH ====
SUPPORT_GROUP=@YourGroup
UPLOAD_CHANNEL=@YourMainChannel
ARCHIVE_CHANNEL=@YourArchiveChannel

# ==== WEB ADMIN PANEL ====
WEB_ENABLED=1
WEB_HOST=127.0.0.1
WEB_PORT=8090
# To'g'ridan-to'g'ri kirish uchun Basic Auth (master proxy ishlatilsa shart emas)
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=change-this-password
# Master domen dropdown'i orqali ulanganda umumiy sir (master bilan bir xil bo'lsin)
WEB_BRIDGE_SECRET=change-this-shared-secret

# ==== BOSHQA ====
TIMEZONE=Asia/Tashkent
