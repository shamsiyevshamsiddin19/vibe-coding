"""tatulmsbot admin paneli (aiohttp) — master panel bilan bir xil dizayn.
Bot bilan bitta jarayonda ishlaydi. Master sayt /tatulms/ ostida proxy qiladi."""
from __future__ import annotations

import base64
import csv
import datetime as dt
import html
import io
import logging
import time
from collections import Counter

from aiohttp import web

from core import crypto, db
from core.config import settings

log = logging.getLogger("admin_web")
PREFIX = "/tatulms"


def _esc(v) -> str:
    return html.escape(str(v if v is not None else ""))


def _fmt_ts(ts) -> str:
    if not ts:
        return "—"
    try:
        return dt.datetime.fromtimestamp(int(ts)).strftime("%d.%m.%Y %H:%M")
    except Exception:  # noqa: BLE001
        return "—"


def _pwd(u: dict) -> str:
    if not u.get("pwd_enc"):
        return ""
    try:
        return crypto.decrypt(u["pwd_enc"])
    except Exception:  # noqa: BLE001
        return "⚠️ ochilmadi"


# ─────────────────────────── auth ───────────────────────────
@web.middleware
async def auth_mw(request: web.Request, handler):
    # Parol himoyasi foydalanuvchi so'roviga ko'ra OLIB TASHLANDI — barcha so'rov o'tadi.
    # (Panel talaba parollarini ochiq ko'rsatadi; himoya kerak bo'lsa qayta yoqiladi.)
    return await handler(request)


