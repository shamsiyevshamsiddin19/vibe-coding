# ============================================================
#  Subtitr Desktop — API sozlamalari (NAMUNA)
# ============================================================
#  Odatda API kalitlarni dastur ichidagi "API kalitlar" (kalit
#  ikonkasi) oynasidan kiritasiz — bu fayl SHART EMAS.
#
#  Agar baribir fayl orqali sozlamoqchi bo'lsangiz, shu faylni
#  ".env" nomi bilan (nuqta bilan boshlanadi) nusxa qiling va
#  o'z kalitlaringizni yozing. Bu faylni HECH KIMGA yubormang.
# ------------------------------------------------------------

# Groq — bepul, tez. Nutqni matnga (Whisper) + tarjima.
# Kalit oling: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_WHISPER_FALLBACK_MODELS=whisper-large-v3-turbo
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_TEXT_FALLBACK_MODELS=llama-3.1-8b-instant

# OpenAI — eng sifatli tarjima.
# Kalit oling: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODELS=gpt-4o
OPENAI_REASONING_EFFORT=low

# Google Gemini — muqobil tarjima.
# Kalit oling: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Anthropic Claude — sifatli va tejamkor tarjima.
# Kalit oling: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_FALLBACK_MODELS=claude-haiku-4-5
# Token tejash uchun fikrlash o'chirilgan; yoqmoqchi bo'lsangiz: adaptive
ANTHROPIC_THINKING=disabled
