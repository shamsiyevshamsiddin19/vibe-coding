# Mustaqil Ish Bot — .env namuna
# Bu faylni .env deb saqlang va o'z qiymatlaringiz bilan to'ldiring.
# DIQQAT: .env faylini hech qachon GitHub'ga yuklamang (sirlar ochilib ketadi)!

# ─── BOT ───
BOT_TOKEN=1234567890:AA-your-telegram-bot-token-here
BOT_USERNAME=your_bot_username

# ─── ADMIN ───
ADMIN_IDS=123456789
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password

# ─── DATABASE ───
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mustaqilbot

# ─── AI PROVAYDERLAR ───
# Claude (asosiy) — console.anthropic.com dan oling
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI (zaxira) — platform.openai.com dan oling
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# AI modellari (default qoldirilsa ham ishlaydi)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_PREMIUM=claude-opus-4-6
OPENAI_MODEL=gpt-4o-mini

# ─── PEXELS (slaydlar uchun fon-foto, ixtiyoriy) — pexels.com/api dan oling ───
PEXELS_API_KEY=

# ─── CLICK TO'LOV ───
CLICK_SERVICE_ID=00000
CLICK_MERCHANT_ID=00000
CLICK_SECRET_KEY=your_click_secret_key
CLICK_MERCHANT_USER_ID=00000
CLICK_RETURN_URL=https://t.me/your_bot_username
CLICK_TX_PREFIX=MUST
BRIDGE_SECRET=your_bridge_secret

# ─── WEB SERVER ───
WEB_HOST=127.0.0.1
WEB_PORT=8092
PUBLIC_BASE_URL=http://your-server-ip/mustaqil

# ─── FAYL SAQLASH ───
TMP_DIR=/tmp/mustaqilbot

# ─── MARKETING / O'SISH (ixtiyoriy) ───
WELCOME_BONUS=2000
CASHBACK_PCT=4
WEB_SEARCH=1
VIP_IDS=
VIP_PRICE=1000

# ─── MINIMUM BALANS TO'LDIRISH ───
MIN_TOPUP=10000
