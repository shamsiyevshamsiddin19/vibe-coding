# Mustaqil Ish Bot — .env namuna
# Bu faylni .env deb saqlang va qiymatlarni to'ldiring

# ─── BOT ───
BOT_TOKEN=
BOT_USERNAME=talabaxizmatlaribot

# ─── ADMIN ───
ADMIN_IDS=
ADMIN_USER=admin
ADMIN_PASSWORD=

# ─── DATABASE ───
DATABASE_URL=postgresql+asyncpg://mustaqil:CHANGE_ME@localhost:5432/mustaqilbot

# ─── AI PROVAYDERLAR ───
# Claude (asosiy) — console.anthropic.com dan oling
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX
# OpenAI (zaxira) — platform.openai.com dan oling
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX

# AI modellari (default qoldirilsa ham ishlaydi)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# ─── CLICK TO'LOV ───
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=
CLICK_RETURN_URL=https://t.me/talabaxizmatlaribot
CLICK_TX_PREFIX=MUST
BRIDGE_SECRET=

# ─── WEB SERVER ───
WEB_HOST=127.0.0.1
WEB_PORT=8092
PUBLIC_BASE_URL=

# ─── FAYL SAQLASH ───
TMP_DIR=/tmp/mustaqilbot

# ─── SUBTITR BOT (dropdown uchun URL) ───
SUBTITR_ADMIN_URL=

# ─── NARXLAR (so'mda, ixtiyoriy — default qiymatlar bor) ───
PRICE_TEZIS=10000
PRICE_MUSTAQIL=15000
PRICE_REFERAT=20000
PRICE_KRASWORD=15000
PRICE_MAQOLA=25000
PRICE_SLAYD=25000
PRICE_KURS=50000
PRICE_DIPLOM=100000

# ─── REFERAL BONUSLAR (so'mda) ───
REF_BONUS_TEZIS=2000
REF_BONUS_MUSTAQIL=3000
REF_BONUS_REFERAT=4000
REF_BONUS_KRASWORD=3000
REF_BONUS_MAQOLA=5000
REF_BONUS_SLAYD=5000
REF_BONUS_KURS=10000
REF_BONUS_DIPLOM=20000

# ─── MINIMUM BALANS TO'LDIRISH ───
MIN_TOPUP=10000
