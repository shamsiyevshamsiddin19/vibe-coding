# Telegram bot token (BotFather dan oling)
BOT_TOKEN=

# Groq API key (https://console.groq.com dan oling)
GROQ_API_KEY=


# Whisper modeli (Groq)
WHISPER_MODEL=whisper-large-v3

# Admin web panel kirishi (http://<server>:8080/admin).
# ADMIN_PASSWORD bo'sh bo'lsa panel yopiq. Kuchli parol qo'ying.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Subtitr ko'rinishi (toza kontur)
# Brendli ko'rinish uchun Inter.ttf ni serverga o'rnating va SUB_FONT=Inter qiling.
# Inter o'rnatilmagan bo'lsa Arial xavfsiz (Windows/Linux da bor).
SUB_FONT=Arial
SUB_FONT_SIZE=22

# Telegram Bot API yuklab olish chegarasi (MB). Oddiy Bot API = 20.
# Local Bot API server bilan 2000 gacha (K1).
MAX_UPLOAD_MB=20

# YouTube/Instagram yuklab olishda maksimal video balandligi (px).
# 720 = HD (tavsiya). Kichikroq = tezroq + kichik fayl.
YTDLP_MAX_HEIGHT=720

# yt-dlp YouTube bot-tekshiruvini (Sign in to confirm) chetlab o'tish.
# Brauzer: chrome / edge / firefox ...  YOKI cookies.txt fayl yo'li (pastdagi).
# Eslatma: Chrome ochiq bo'lsa cookie bazasi qulflanadi -> cookiesiz davom etadi.
YTDLP_COOKIES_BROWSER=
# YTDLP_COOKIES_FILE=C:\path\cookies.txt

# Mini App: dev-rejim brauzerда initData'siz sinash (FAQAT ishlab chiqishда!).
# Telegram (prod, HTTPS) da 0 qiling. MINIAPP_MAX_MB — maksimal yuklash hajmi.
MINIAPP_DEV=0
MINIAPP_MAX_MB=500

# Vaqtinchalik fayllar papkasi
WORK_DIR=tmp
